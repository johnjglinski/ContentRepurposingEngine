# ============================================
# Resume Scanner SaaS - PRODUCTION Environment Config
# ============================================
# Deployed on Vercel (or Railway/DigitalOcean)
# Port: Managed by hosting platform
# IMPORTANT: Replace ALL placeholder values before deployment

# ----- App URL -----
# Update to your production domain after deployment
# Example: https://resume.j3cfamily.studio
NEXT_PUBLIC_APP_URL=https://resume.j3cfamily.studio

# ----- Stripe Configuration (LIVE MODE) -----
# Get LIVE keys from: https://dashboard.stripe.com/apikeys
# ⚠️ DO NOT use test keys in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET_HERE

# ----- Stripe Price IDs (LIVE) -----
# Create these products at: https://dashboard.stripe.com/products

# Product 1: "Single Resume Scan" - $3.00 (ONE-TIME payment)
NEXT_PUBLIC_RESUME_SCAN_PRICE_ID=price_YOUR_LIVE_SCAN_PRICE_ID_HERE

# Product 2: "Unlimited Monthly Plan" - $9.00/month (SUBSCRIPTION)
NEXT_PUBLIC_RESUME_UNLIMITED_PRICE_ID=price_YOUR_LIVE_UNLIMITED_PRICE_ID_HERE

# ----- AI API Configuration -----
# Option A: OpenAI (recommended for production reliability)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Option B: LM Studio (self-hosted - only if you have a dedicated server)
# LM_STUDIO_URL=http://your-server-ip:1234/v1
# LM_STUDIO_MODEL=local-model

# ----- SendGrid Email Configuration -----
SENDGRID_API_KEY=SG.YOUR_PRODUCTION_SENDGRID_KEY_HERE
EMAIL_FROM=noreply@j3cfamily.studio

# ----- Node Environment -----
NODE_ENV=production
