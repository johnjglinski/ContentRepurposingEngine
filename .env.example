# ============================================
# Content Repurposing Engine - Environment Config
# ============================================

# ----- Appwrite Configuration -----
# Appwrite Cloud endpoint (or self-hosted)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id-here

# Appwrite API Key (server-side only - DO NOT prefix with NEXT_PUBLIC_)
APPWRITE_API_KEY=your_appwrite_api_key_here

# Toggle to use Appwrite functions instead of local processing
# Set to 'true' only if you have deployed Appwrite functions
USE_APPWRITE_CHECKOUT=false
USE_APPWRITE_WEBHOOK=false
USE_APPWRITE_GENERATE=false
USE_APPWRITE_EMAIL=false

# ----- LM Studio Configuration -----
# LM Studio provides an OpenAI-compatible API endpoint
# Default: http://localhost:1234/v1
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# ----- OpenAI Configuration (fallback if LM Studio is not running) -----
# OPENAI_API_KEY=sk-your-openai-key-here

# ----- App URL -----
# Used for Stripe redirect URLs and CORS allowed origins
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed origins for CORS (no wildcard)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ----- Stripe Configuration -----
# Get your test keys from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs - create products at https://dashboard.stripe.com/test/products
# Each product should have a recurring price with interval=month
STRIPE_BASIC_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_
STRIPE_AGENCY_PRICE_ID=price_

# Public Stripe Price IDs (for client-side StripeCheckout component)
NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_

# ----- SendGrid Configuration -----
# Get credentials from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# ----- Azure Configuration (Legacy - for reference) -----
# AZURE_FUNCTION_URL=https://your-function-app.azurewebsites.net/api
