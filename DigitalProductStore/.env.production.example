# ============================================
# Digital Product Store - PRODUCTION Environment Config
# ============================================
# Deployed on Vercel (or Railway/DigitalOcean)
# Port: Managed by hosting platform
# IMPORTANT: Replace ALL placeholder values before deployment

# ----- App URL -----
# Update to your production domain after deployment
# Example: https://store.j3cfamily.studio
NEXT_PUBLIC_APP_URL=https://store.j3cfamily.studio

# ----- Stripe Configuration (LIVE MODE) -----
# Get LIVE keys from: https://dashboard.stripe.com/apikeys
# ⚠️ DO NOT use test keys in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET_HERE

# ----- Stripe Price IDs (One-Time Payments - LIVE) -----
# Create these products at: https://dashboard.stripe.com/products
# Each product must be a ONE-TIME payment (not subscription)

# Product 1: "30 AI Prompts for Social Media Managers" - $7.00
NEXT_PUBLIC_STORE_SOCIAL_PROMPTS_PRICE_ID=price_YOUR_LIVE_PRICE_ID_1_HERE

# Product 2: "Content Calendar Template (Notion + Excel)" - $9.00
NEXT_PUBLIC_STORE_CALENDAR_TEMPLATE_PRICE_ID=price_YOUR_LIVE_PRICE_ID_2_HERE

# Product 3: "Freelancer Rate Calculator + Contract Template" - $12.00
NEXT_PUBLIC_STORE_RATE_CALCULATOR_PRICE_ID=price_YOUR_LIVE_PRICE_ID_3_HERE

# Product 4: "Side Hustle Idea Generator (50 Prompts)" - $7.00
NEXT_PUBLIC_STORE_SIDE_HUSTLE_PROMPTS_PRICE_ID=price_YOUR_LIVE_PRICE_ID_4_HERE

# Product 5: "Resume Builder Prompt Pack" - $9.00
NEXT_PUBLIC_STORE_RESUME_BUILDER_PRICE_ID=price_YOUR_LIVE_PRICE_ID_5_HERE

# ----- SendGrid Email Configuration -----
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_PRODUCTION_SENDGRID_KEY_HERE
EMAIL_FROM=noreply@j3cfamily.studio

# ----- Node Environment -----
NODE_ENV=production
